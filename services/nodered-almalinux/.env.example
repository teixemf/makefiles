# This file is interpreted by Bash. Quote values containing spaces, hash (#),
# dollar signs ($), semicolons, or other special characters.
# Protect the real file: chmod 600 .env

# Nome DNS usado pelo Nginx e pelos certificados.
FQDN=nodered.example.com

# Node-RED runtime. The installer uses the Node.js package provided by AlmaLinux;
# Node-RED 5.x requer Node.js 22 ou superior.
NODERED_VERSION=latest
NODERED_USER=nodered
NODERED_GROUP=nodered
NODERED_HOME=/var/lib/nodered
NODERED_BIND=127.0.0.1
NODERED_PORT=1880
NODERED_SESSION_SECONDS=86400

# Editor and Admin API authentication.
NODERED_ADMIN_USER=admin

# Option A: plaintext password only in .env. It is converted to bcrypt during
# installation and the service receives only the hash.
NODERED_ADMIN_PASSWORD=ALTERAR-ANTES-DE-INSTALAR

# Option B, preferred: leave PASSWORD empty and provide a bcrypt $2a$/$2b$/$2y$ hash.
NODERED_ADMIN_PASSWORD_HASH=

# Segredo de cifragem das credenciais dos flows. "make init" tenta gerar um.
# Do not change it after Node-RED starts storing credentials.
NODE_RED_CREDENTIAL_SECRET=

# Optional: also protect all endpoints created by HTTP In nodes.
NODERED_HTTP_NODE_AUTH=false
NODERED_HTTP_NODE_USER=api
NODERED_HTTP_NODE_PASSWORD=
NODERED_HTTP_NODE_PASSWORD_HASH=

# TLS auto-assinado, usado por "make install" e "make cert-selfsigned".
SELF_SIGNED_DAYS=825

# Certbot with Let's Encrypt DNS-01, used by cert-le-stag/cert-le-prod.
CERTBOT_EMAIL=admin@example.com
CERTBOT_DNS_PROVIDER=cloudflare
CERTBOT_DNS_PROPAGATION_SECONDS=120
CERTBOT_KEY_TYPE=ecdsa
CERTBOT_ELLIPTIC_CURVE=secp256r1
CERTBOT_RSA_KEY_SIZE=3072
# Empty values use FQDN-specific names under /etc/letsencrypt and
# /usr/local/libexec; defina apenas se precisar de outros caminhos.
CERTBOT_DNS_CREDENTIALS_FILE=
CERTBOT_DEPLOY_HOOK=

# Cloudflare is the default provider. Create a zone-scoped token with
# Zone:DNS:Edit and Zone:Zone:Read. After the first run, this variable can be
# empty if CERTBOT_DNS_CREDENTIALS_FILE already exists.
CLOUDFLARE_API_TOKEN=

# For another provider supported by EPEL, change CERTBOT_DNS_PROVIDER and
# create CERTBOT_DNS_CREDENTIALS_FILE in the format required by the plugin.

# Upgrade policy.
# false by default because upgrading all palette nodes can introduce
# incompatible changes. Use "make upgrade-nodes" explicitly.
UPGRADE_PALETTE_NODES=false
BACKUP_ROOT=/var/backups/nodered
BACKUP_RETENTION_DAYS=30

# Allow RHEL derivatives in addition to AlmaLinux.
ALLOW_RHEL_COMPAT=false
