# Este ficheiro é interpretado por Bash. Use aspas em valores com espaços,
# cardinal (#), dólar ($), ponto e vírgula ou outros caracteres especiais.
# Proteja o ficheiro real: chmod 600 .env

# Nome DNS usado pelo Nginx e pelos certificados.
FQDN=nodered.example.com

# Runtime Node-RED.
NODE_MAJOR=24
NODERED_VERSION=latest
NODERED_USER=nodered
NODERED_GROUP=nodered
NODERED_HOME=/var/lib/nodered
NODERED_BIND=127.0.0.1
NODERED_PORT=1880
NODERED_SESSION_SECONDS=86400

# Autenticação do editor e Admin API.
NODERED_ADMIN_USER=admin

# Opção A: palavra-passe em claro apenas no .env. Na instalação é convertida
# para bcrypt e o serviço recebe apenas o hash.
NODERED_ADMIN_PASSWORD=ALTERAR-ANTES-DE-INSTALAR

# Opção B, preferível: deixe PASSWORD vazia e forneça um bcrypt $2a$/$2b$/$2y$.
NODERED_ADMIN_PASSWORD_HASH=

# Segredo de cifragem das credenciais dos flows. "make init" tenta gerar um.
# Não o altere depois de começar a guardar credenciais no Node-RED.
NODE_RED_CREDENTIAL_SECRET=

# Opcional: proteger também todos os endpoints criados por nós HTTP In.
NODERED_HTTP_NODE_AUTH=false
NODERED_HTTP_NODE_USER=api
NODERED_HTTP_NODE_PASSWORD=
NODERED_HTTP_NODE_PASSWORD_HASH=

# TLS auto-assinado, usado por "make install" e "make cert-selfsigned".
SELF_SIGNED_DAYS=825

# Let's Encrypt DNS-01, usado por cert-le-stag/cert-le-prod.
ACME_EMAIL=admin@example.com
ACME_DNS_PROVIDER=dns_cf
ACME_DNS_SLEEP=120
ACME_KEY_LENGTH=ec-256
ACME_GIT_REF=master
ACME_HOME=/opt/acme.sh
ACME_CONFIG_ROOT=/etc/acme.sh
ACME_CERT_ROOT=/var/lib/acme.sh

# Cloudflare — token restrito a DNS Edit e Zone Read para a zona necessária.
CF_Token=
CF_Account_ID=
# CF_Zone_ID=

# Para outro fornecedor, mude ACME_DNS_PROVIDER e adicione aqui as variáveis
# exigidas pelo respectivo hook de https://github.com/acmesh-official/acme.sh/wiki/dnsapi
# Exemplos:
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# OVH_AK=
# OVH_AS=
# OVH_CK=

# Actualização.
# false por defeito porque actualizar todos os nós da palette pode introduzir
# alterações incompatíveis. Use "make upgrade-nodes" explicitamente.
UPGRADE_PALETTE_NODES=false
BACKUP_ROOT=/var/backups/nodered
BACKUP_RETENTION_DAYS=30

# Permitir derivados RHEL além de AlmaLinux.
ALLOW_RHEL_COMPAT=false
