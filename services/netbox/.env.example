# Paths for an existing NetBox installation. Values are interpreted as Bash.
NETBOX_DIR=/opt/netbox
NETBOX_APP=/opt/netbox/netbox
NETBOX_REQUIREMENTS=/opt/netbox/local_requirements.txt
NETBOX_SECRETS_FILE=/etc/netbox/secrets.env
NETBOX_PYTHON=/opt/netbox/venv/bin/python
NETBOX_PIP=/opt/netbox/venv/bin/pip
NETBOX_SYSTEM_PYTHON=/usr/bin/python3

# NetBox's dedicated system account and systemd units.
NETBOX_USER=netbox
NETBOX_SERVICE=netbox
NETBOX_RQ_SERVICE=netbox-rq
NETBOX_HOUSEKEEPING_SERVICE=netbox-housekeeping

# Backups include secrets and database data. Keep this outside the application tree.
NETBOX_BACKUP_ROOT=/var/backups/netbox
NETBOX_BACKUP_RETENTION_DAYS=14
